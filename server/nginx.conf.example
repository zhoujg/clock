# 时钟应用 - Nginx 配置示例
#
# 将此段添加到 neihou.cn 的 server 块中
#
# 目录结构：
#   /www/wwwroot/neihou/public/clock/    ← 前端（neihou.cn/clock/）
#   /www/wwwroot/neihou/clockserver/     ← 后端 PHP（不暴露在 public 下）

# ============================================
# API 请求代理到 clockserver
# 浏览器请求 /clockserver/api/xxx.php
#   → Nginx 映射到 /www/wwwroot/neihou/clockserver/api/xxx.php
# ============================================
# ============================================
# ⬇️ 时钟 API：放在 enable-php-83.conf 之前
# ============================================
location ~ ^/clockserver/api/(.+)\.php$ {
    include fastcgi_params;
    fastcgi_pass unix:/tmp/php-cgi-83.sock;
    fastcgi_param SCRIPT_FILENAME /www/wwwroot/neihou/clockserver/api/$1.php;
    fastcgi_read_timeout 60s;
}

# 上传大小限制
client_max_body_size 10m;




