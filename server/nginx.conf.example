# 时钟应用 - Nginx 配置
# 将此文件放到 /etc/nginx/sites-available/clock 并创建软链接到 sites-enabled/

server {
    listen 80;
    server_name your-domain.com;  # 修改为你的域名

    root /var/www/clock;           # 修改为实际路径
    index index.html;

    # 静态文件
    location / {
        try_files $uri $uri/ =404;
    }

    # PHP API（如果使用 PHP-FPM）
    location /api/ {
        # 只允许 api/ 目录下的 .php 文件
        if (!-f $request_filename) {
            return 404;
        }

        include fastcgi_params;
        fastcgi_pass unix:/var/run/php/php8.2-fpm.sock;  # 修改为你的 PHP-FPM 版本
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        fastcgi_read_timeout 60s;
    }

    # 安全：禁止直接访问 server 目录中的非 API 文件
    location ~ ^/server/(?!api/) {
        deny all;
    }

    location ~ ^/\. {
        deny all;
    }

    # 上传大小限制
    client_max_body_size 10m;
}
